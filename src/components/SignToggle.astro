---
interface Props {
  id: string;
  title: string;
}

const { id, title } = Astro.props;
---

<div class="sign-toggle-wrap">
  <button
    type="button"
    class="sign-toggle"
    data-sign-toggle
    data-sign-id={id}
    data-sign-title={title}
    aria-pressed="false"
  >
    <span data-sign-label>Quiero firmar esto</span>
  </button>
</div>
